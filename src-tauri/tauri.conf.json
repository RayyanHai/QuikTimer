{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuikTimer",
  "version": "0.1.0",
  "identifier": "com.quiktimer.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "panel",
        "title": "QuikTimer",
        "width": 220,
        "height": 110,
        "minWidth": 160,
        "minHeight": 50,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "shadow": true,
        "focus": false
      },
      {
        "label": "settings",
        "title": "QuikTimer Settings",
        "width": 380,
        "height": 580,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
